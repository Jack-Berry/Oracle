# Frontend env (Vite). Copy to frontend/.env.local for local overrides, or
# configure equivalents in Vercel project settings for production.

# Backend base URL. When set, all /api/... fetches and the Socket.IO client
# connect to this origin instead of window.location.origin. Leave unset in
# local dev — Vite's proxy forwards /api and /socket.io to localhost:3001.
# VITE_API_BASE_URL=https://oracle-api.onrender.com
