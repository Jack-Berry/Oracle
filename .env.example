# ─── Required API keys ───────────────────────────────────────────────────────

# Anthropic API Key — get one at https://console.anthropic.com
ANTHROPIC_API_KEY=your-api-key-here

# ElevenLabs API Key — get one at https://elevenlabs.io
ELEVENLABS_API_KEY=your-elevenlabs-key-here

# Legacy hyphenated env var names are still read as a fallback for backwards
# compatibility. Prefer the underscored names above for new setups:
#   Anthropic-API-Key   → ANTHROPIC_API_KEY
#   ElevenLabs-API-Key  → ELEVENLABS_API_KEY

# Model to use for Oracle responses. Default: claude-haiku-4-5
# Other options: claude-sonnet-4-6, claude-opus-4-7
# ORACLE_MODEL=claude-haiku-4-5

# Backend port (default: 3001)
# PORT=3001

# ─── PostgreSQL ──────────────────────────────────────────────────────────────

# Production: a single connection string (Neon, Render Postgres, etc.). When
# set, it wins over the DB_* vars below. Use Neon's *pooled* endpoint
# (host ends in `-pooler...`) for serverless-friendly connection re-use.
# SSL is enabled automatically when NODE_ENV=production.
# DATABASE_URL=postgresql://USER:PASSWORD@ep-something-pooler.region.aws.neon.tech/oracle?sslmode=require

# Local dev fallback (used when DATABASE_URL is not set).
DB_HOST=localhost
DB_PORT=5432
DB_NAME=oracle
DB_USER=postgres
DB_PASSWORD=

# ─── Access protection (shared password) ─────────────────────────────────────

# The shared access code clients must present to use the app. Required in
# production (NODE_ENV=production). Set it to a long random string.
#   openssl rand -hex 24
# Clients send it in `Authorization: Bearer <token>` and the Socket.IO
# handshake auth.token. Frontend stores it under `oracle_access_token` in
# localStorage after the gate screen accepts it.
ORACLE_ACCESS_TOKEN=

# Force the auth requirement on outside production (useful for testing the
# auth path locally). Default: off in dev, on in production.
# ORACLE_REQUIRE_AUTH=true

# ─── CORS allowlist ──────────────────────────────────────────────────────────

# Comma-separated list of origins permitted to call /api and connect to
# Socket.IO. Required in production. In development, localhost + RFC1918
# private LAN ranges are additionally allowed automatically.
# Example:
# ALLOWED_ORIGINS=https://oracle.vercel.app,https://oracle.example.com
ALLOWED_ORIGINS=

# ─── Rate limits (per IP, 15-minute window) ──────────────────────────────────

# Defaults shown are used if these are unset.
# ORACLE_RATE_LIMIT=30
# TTS_RATE_LIMIT=30
# MERCHANT_RATE_LIMIT=60
# API_RATE_LIMIT=600

# ─── Raspberry Pi + Cloudflare Tunnel production example ─────────────────────
#
# On the Pi, copy this block into the real `.env` (above the `#` markers) and
# fill in the secrets. The backend will serve the built React app from
# ../frontend/dist on the same port, so Cloudflare Tunnel only needs to point
# at http://localhost:3001.
#
# NODE_ENV=production
# PORT=3001
# DATABASE_URL=postgresql://oracle:STRONG_PASSWORD@localhost:5432/oracle
# ORACLE_ACCESS_TOKEN=                # openssl rand -hex 24
# ALLOWED_ORIGINS=https://oraclednd.uk
# ANTHROPIC_API_KEY=
# ELEVENLABS_API_KEY=                 # optional — browser TTS fallback otherwise
# ORACLE_MODEL=claude-haiku-4-5       # optional
