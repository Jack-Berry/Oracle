# Anthropic API Key — get one at https://console.anthropic.com
ANTHROPIC_API_KEY=your-api-key-here

# ElevenLabs API Key — get one at https://elevenlabs.io
ELEVENLABS_API_KEY=your-elevenlabs-key-here

# Legacy hyphenated env var names are still read as a fallback for backwards
# compatibility. Prefer the underscored names above for new setups:
#   Anthropic-API-Key   → ANTHROPIC_API_KEY
#   ElevenLabs-API-Key  → ELEVENLABS_API_KEY

# Model to use for Oracle responses. Default: claude-haiku-4-5
# Other options: claude-sonnet-4-6, claude-opus-4-7
# ORACLE_MODEL=claude-haiku-4-5

# Backend port (default: 3001)
# PORT=3001

# PostgreSQL connection (required for campaign/party/session persistence)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=oracle
DB_USER=postgres
DB_PASSWORD=
